# ─────────────────────────────────────────────
#  parguszv1 — .env şablonu
#  Bu dosyayı doldurup kaydet, sonra botu başlat
# ─────────────────────────────────────────────

# Discord Bot Token (https://discord.com/developers/applications)
DISCORD_TOKEN=YOUR_DISCORD_TOKEN_HERE

# Discord Uygulama Client ID
DISCORD_CLIENT_ID=YOUR_CLIENT_ID_HERE

# Spotify API (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID
SPOTIFY_CLIENT_SECRET=YOUR_SPOTIFY_CLIENT_SECRET

# Genius API (isteğe bağlı, şarkı sözleri için)
# https://genius.com/api-clients
GENIUS_TOKEN=YOUR_GENIUS_TOKEN_HERE

# Web Dashboard Ayarları
DASHBOARD_SECRET_KEY=parguszv1_super_secret_key_change_this
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000
